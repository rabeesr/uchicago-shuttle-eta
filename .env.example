# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; `.env.example` is committed with placeholders only.

# --- Supabase (both worker and web) ---
SUPABASE_URL=https://<project>.supabase.co

# Service-role key. WORKER-ONLY — bypasses RLS, must never land on the web or
# in a public bundle. Get it from Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Next.js public (web only) ---
# Safe to expose in the client bundle; gated by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-or-anon-key>
# The @supabase/ssr client reads NEXT_PUBLIC_SUPABASE_ANON_KEY — alias it to
# your publishable key (new Supabase naming for the same value).
NEXT_PUBLIC_SUPABASE_ANON_KEY=<same as PUBLISHABLE_KEY>

# --- Worker ---
PASSIO_SYSTEM_ID=1068
USER_AGENT=uchicago-shuttle-eta/0.1 (contact: rrafiq0@uchicago.edu)
WORKER_HEALTH_PORT=8080
