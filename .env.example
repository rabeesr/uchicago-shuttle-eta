# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; `.env.example` is committed with placeholders only.

# --- Supabase ---
SUPABASE_URL=https://<project>.supabase.co

# Service-role ("secret") key. WORKER-ONLY — bypasses RLS, must never land on
# the web or in a public bundle. Supabase → Project Settings → API → Secret keys.
SUPABASE_SERVICE_ROLE_KEY=<sb_secret_...>

# --- Next.js public (web) ---
# Safe to expose in the client bundle; gated by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sb_publishable_... or legacy anon key>

# --- Clerk (web only) ---
# Clerk is integrated with Supabase via the "Native Integration" —
# Clerk-issued session JWTs are attached to every Supabase request and
# verified against Clerk's JWKS. Configure in:
#   Clerk dashboard → Configure → Integrations → Supabase
#   Supabase dashboard → Authentication → Sign In / Up → Third-Party Auth → Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<pk_test_... or pk_live_...>
CLERK_SECRET_KEY=<sk_test_... or sk_live_...>
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Worker ---
PASSIO_SYSTEM_ID=1068
USER_AGENT=uchicago-shuttle-eta/0.1 (contact: rrafiq0@uchicago.edu)
WORKER_HEALTH_PORT=8080
